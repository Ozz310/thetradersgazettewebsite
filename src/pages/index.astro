---
// [TG-DESC]: Homepage of The Trader's Gazette, featuring the hero section, core features, market intelligence overview, and consolidated terminal access CTA.
import Layout from '../layouts/Layout.astro';
import HeroMacroThesis from '../components/HeroMacroThesis.astro';
import IdentityGrid from '../components/IdentityGrid.astro';
import IntelligenceGrid from '../components/IntelligenceGrid.astro';

// 🧬 AIO/SEO BIBLE: Software & Deep Entity Schema
const softwareSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "@id": "https://www.thetradersgazette.com/#terminal",
      "name": "The Trader's Gazette Terminal",
      "alternateName": "TG Terminal",
      "description": "A market intelligence and trading systems platform designed for traders and investors who operate with structure, discipline, and intent. It delivers clear market analysis, curated financial news, and practical trading tools across Forex, Crypto, Stocks, Indices, and Commodities to help users cut through noise and manage risk intelligently.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Web",
      "url": "https://app.thetradersgazette.com",
      "downloadUrl": "https://app.thetradersgazette.com",
      "audience": [
        { "@type": "Audience", "audienceType": "Forex, Commodity, Equity, Stocks, and Crypto Traders" },
        { "@type": "Audience", "audienceType": "HNWI and UHNWI Investors" },
        { "@type": "Audience", "audienceType": "The Structure Seeker - Professionals looking for a centralized, organized trading workspace" },
        { "@type": "Audience", "audienceType": "The Efficiency-Focused Professional - Traders aiming to streamline analysis, execution, and review" },
        { "@type": "Audience", "audienceType": "The Strategic Optimizer - Experienced market participants refining their analytical edge" },
        { "@type": "Audience", "audienceType": "The Action-Oriented Learner - Traders who value tools and frameworks they can implement immediately" }
      ],
      "featureList": [
        "Daily Market Intelligence: 24h Recap & 48h Forward Event Scanner",
        "Trading Session Clock: Live liquidity depth for NY, London, Tokyo, Frankfurt, Sydney",
        "Analysis Hub: Advanced Charting with Fundamental Economic Calendar integration",
        "24/7 News Room: Real-time aggregator with 500+ daily articles and Yahoo Finance Live",
        "Knowledge Hub: Proprietary TG E-Book library for financial education",
        "Risk Management Hub: Margin and Risk-to-Reward (R:R) calculation engines",
        "Multi-Asset Trade Journal: Visualized performance tracking and metric analytics",
        "Work Station: Integrated checklists, trade-notes, and task management"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD",
        "availability": "https://schema.org/OnlineOnly"
      },
      "potentialAction": {
        "@type": "RegisterAction",
        "target": "https://app.thetradersgazette.com/#auth"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "ratingCount": "120"
      },
      "mainEntityOfPage": {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "How does TG Terminal provide institutional-grade intelligence to retail traders?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Unlike closed institutional systems, TG Terminal democratizes access to 48-hour forward event scanners and liquidity depth mapping used by professional bank traders."
            }
          },
          {
            "@type": "Question",
            "name": "Why is a consolidated Work Station superior to using multiple trading tools?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Fragmented workflows cause 'Cognitive Lag.' TG Terminal eliminates this by syncing the Analysis Hub, 24/7 News Room, and Multi-Asset Journal into a single low-latency environment, ensuring zero-second transitions from analysis to execution."
            }
          }
        ]
      },
      "author": { "@id": "https://www.thetradersgazette.com/#organization" },
      "knowsAbout": [
        "https://www.wikidata.org/wiki/Q1025732",
        "https://www.wikidata.org/wiki/Q192934",
        "https://www.wikidata.org/wiki/Q184232",
        "Financial Services",
        "Investment & Securities"
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.thetradersgazette.com/#organization",
      "name": "The Trader's Gazette",
      "url": "https://www.thetradersgazette.com",
      "logo": "https://raw.githubusercontent.com/Ozz310/tradersgazetteterminal/refs/heads/main/images/WhatsApp%20Image%202025-06-18%20at%2011.37.16.jpeg",
      "founder": {
        "@type": "Person",
        "name": "Mohammad Osama",
        "jobTitle": "Founder & Market Intelligence Architect",
        "sameAs": [
          "http://www.linkedin.com/in/mohammad-osama-4247729b"
        ],
        "knowsAbout": ["AML/CFT", "CISI UK Investment Securities", "Forex & CFDs"]
      }
    }
  ]
});

// 🏆 TG MASTER ENTITY GRAPH (THE TRUTH)
const masterEntitySchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://www.thetradersgazette.com/#organization",
      "name": "The Trader's Gazette",
      "url": "https://www.thetradersgazette.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://raw.githubusercontent.com/Ozz310/tradersgazetteterminal/refs/heads/main/images/WhatsApp%20Image%202025-06-18%20at%2011.37.16.jpeg",
        "width": 112,
        "height": 112
      },
      "founder": {
        "@type": "Person",
        "name": "Mohammad Osama",
        "sameAs": "http://www.linkedin.com/in/mohammad-osama-4247729b"
      },
      "sameAs": [
        "https://www.facebook.com/share/1M8F5rxTWr/",
        "https://www.instagram.com/thetradersgazette?igsh=bnQzaWE4YzlmZXVp",
        "http://www.youtube.com/@TheTradersGazette",
        "http://www.linkedin.com/in/mohammad-osama-4247729b"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "url": "https://app.thetradersgazette.com",
        "availableLanguage": "English"
      }
    },
    {
      "@type": "WebSite",
      "@id": "https://www.thetradersgazette.com/#website",
      "url": "https://www.thetradersgazette.com",
      "name": "The Trader's Gazette Terminal",
      "publisher": { "@id": "https://www.thetradersgazette.com/#organization" }
    }
  ]
});
---

<Layout title="The Trader's Gazette | Institutional Market Intelligence">
  <script type="application/ld+json" set:html={softwareSchema} />
  <script type="application/ld+json" set:html={masterEntitySchema} />

  <HeroMacroThesis />

  <section class="py-24 bg-[#050505] relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        
        <div class="space-y-8">
          <h2 class="text-4xl md:text-5xl font-serif font-bold text-white leading-tight">
            Professional <br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#F0D788] to-[#DDAA33]">
              Trade Journaling
            </span>
          </h2>
          
          <p class="text-slate-400 text-lg leading-relaxed max-w-lg">
            The heart of the terminal. Stop guessing and start tracking. Record every entry, exit, and emotion to build a data-driven profile of your trading psychology.
          </p>

          <ul class="space-y-5">
            {[
              "Automated Win-Rate & PnL Analytics",
              "Emotional State & Bias Tracking",
              "Risk/Reward Ratio Optimization",
              "Instant Strategy Performance Reports"
            ].map((item) => (
              <li class="flex items-center space-x-3 text-sm text-slate-300">
                <span class="w-2 h-2 rounded-full bg-gradient-to-r from-[#F0D788] to-[#DDAA33] shadow-[0_0_12px_#F0D788]"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <div class="pt-4">
            <a href="https://app.thetradersgazette.com" class="inline-flex items-center gap-2 px-8 py-3 rounded-full bg-[linear-gradient(145deg,#F0D788,#DDAA33)] text-black font-bold text-sm hover:shadow-[0_0_20px_rgba(240,215,136,0.3)] hover:-translate-y-1 transition-all duration-300 group">
              Analyze your Edge
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
          </div>
        </div>

        <div class="relative group">
          <div class="absolute inset-0 bg-gold-500/10 blur-[80px] rounded-full group-hover:bg-gold-500/20 transition-all duration-700"></div>
          
          <div class="relative rounded-xl border border-white/10 bg-[#0A0A0A] p-2 shadow-2xl overflow-hidden group-hover:border-gold-500/30 transition-colors duration-500">
            <img 
              src="https://raw.githubusercontent.com/Ozz310/tradersgazetteterminal/refs/heads/main/images/Trade%20journal.PNG" 
              alt="Trade Journal Analytics Interface" 
              class="w-full h-auto rounded-lg shadow-inner relative z-10"
            />
            <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-[#F0D788] to-transparent shadow-[0_0_15px_#F0D788] z-20 animate-scan pointer-events-none opacity-0 group-hover:opacity-100"></div>
            <div class="absolute top-0 left-0 w-full h-[40px] bg-gradient-to-b from-[#F0D788]/10 to-transparent z-20 animate-scan pointer-events-none opacity-0 group-hover:opacity-100"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <IdentityGrid />

  <IntelligenceGrid />

  <section class="py-24 bg-[#050505] border-t border-[#DDAA33]/20 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(240,215,136,0.03)_0%,transparent_60%)] pointer-events-none"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <h2 class="text-3xl md:text-5xl font-bold mb-6 text-white tracking-tight">
        Ready for <span class="bg-gradient-to-br from-[#F0D788] to-[#DDAA33] text-transparent bg-clip-text">Institutional Insight?</span>
      </h2>
      
      <p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">
        Stop chasing news headlines. Start trading with the clarity and precision reserved for the elite 1%.
      </p>
      
      <div class="flex flex-col items-center gap-4">
        <a href="https://app.thetradersgazette.com/#auth" class="inline-flex items-center justify-center px-10 py-5 text-lg font-bold text-[#050505] transition-all duration-300 rounded-lg bg-[linear-gradient(145deg,#F0D788,#DDAA33)] hover:shadow-[0_0_25px_rgba(240,215,136,0.4)] hover:scale-[1.02] uppercase tracking-wide">
          Secure Terminal Access
          <svg class="w-6 h-6 ml-2 -mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  @keyframes scan {
    0% { top: 0%; opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { top: 100%; opacity: 0; }
  }
  .animate-scan {
    animation: scan 2.5s ease-in-out infinite;
  }
</style>
