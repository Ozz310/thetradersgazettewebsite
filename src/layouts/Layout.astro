---
// [TG-DESC]: Global Layout Shell. Orchestrates SEO Strategy, Master Entity Graph Injection, and Obsidian Void #050505 theming across the entire website.

import '../styles/global.css';
import Header from '../components/Header';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Professional market intelligence & trading terminal. Access daily analysis, advanced charts, risk management tools, and trade journaling. Built for structure, discipline, and intent."
} = Astro.props;

// 🏆 THE SOVEREIGN DNA: MASTER ENTITY GRAPH
// Source: _00_TG_SEO_AIO_BIBLE [Lines 171-217]
const masterGraphSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://www.thetradersgazette.com/#organization",
      "name": "The Trader's Gazette",
      "url": "https://www.thetradersgazette.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://raw.githubusercontent.com/Ozz310/tradersgazetteterminal/refs/heads/main/images/WhatsApp%20Image%202025-06-18%20at%2011.37.16.jpeg",
        "width": 112,
        "height": 112
      },
      "founder": {
        "@type": "Person",
        "name": "Mohammad Osama",
        "sameAs": "http://www.linkedin.com/in/mohammad-osama-4247729b"
      },
      "sameAs": [
        "https://www.facebook.com/share/1M8F5rxTWr/",
        "https://www.instagram.com/thetradersgazette?igsh=bnQzaWE4YzlmZXVp",
        "http://www.youtube.com/@TheTradersGazette",
        "http://www.linkedin.com/in/mohammad-osama-4247729b"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "url": "https://app.thetradersgazette.com",
        "availableLanguage": "English"
      }
    },
    {
      "@type": "WebSite",
      "@id": "https://www.thetradersgazette.com/#website",
      "url": "https://www.thetradersgazette.com",
      "name": "The Trader's Gazette Terminal",
      "publisher": { "@id": "https://www.thetradersgazette.com/#organization" }
    }
  ]
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title} | Trader's Gazette</title>
    <meta name="description" content={description} />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-1S5YJF7H6S"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-1S5YJF7H6S');
    </script>

    <script type="application/ld+json" set:html={masterGraphSchema} />

    <slot name="head" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
  </head>

  <body class="bg-[#050505] text-slate-50 selection:bg-gold-500/30">
    <div class="relative min-h-screen flex flex-col">
      <div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-gold-500/5 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-blue-500/5 rounded-full blur-[120px]"></div>
      </div>

      <Header client:load />

      <main class="flex-grow relative z-10">
        <slot />
      </main>

      <Footer />
    </div>
  </body>
</html>
