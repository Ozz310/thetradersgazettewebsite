---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title} | Trader's Gazette</title>
    <meta name="description" content={description} />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-1S5YJF7H6S"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-1S5YJF7H6S');
    </script>

    <script type="application/ld+json" set:html={masterGraphSchema} />

    <slot name="head" />

    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">
    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>
    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap\" rel=\"stylesheet\">
  </head>

  <body class="bg-[#050505] text-slate-50 selection:bg-gold-500/30">
    <div class="relative min-h-screen flex flex-col">
      <div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-gold-500/5 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-blue-500/5 rounded-full blur-[120px]"></div>
      </div>

      <Header client:load />

      <main class="flex-grow relative z-10">
        <slot />
      </main>

      <Footer />
    </div>
  </body>
</html>
