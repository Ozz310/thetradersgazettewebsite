---
// COMPONENT: IntelligenceGrid (Final Protocol v9.0)
// MOBILE: "The Levitation" - Dead Center, Continuous Float, No Interaction.
// DESKTOP: "The Kinetic Stage" - Grounded, Lift + Glow on Hover.
---

<section id="features" class="py-24 md:py-32 bg-[#050505] relative overflow-hidden">
  <div class="absolute inset-0 bg-[#050505]"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-[300px] md:h-[500px] bg-gold-500/5 blur-[80px] md:blur-[120px] rounded-full pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="text-center mb-16 md:mb-24">
      <h2 class="text-3xl md:text-5xl font-serif font-bold text-slate-100 mb-4 md:mb-6">
        Intelligence <span class="italic text-transparent bg-clip-text bg-gradient-to-r from-[#F0D788] to-[#DDAA33]">Modules</span>
      </h2>
      <p class="text-slate-400 max-w-2xl mx-auto text-base md:text-lg px-4">
        Institutional-grade tools designed for total market awareness. No fluff. Just data.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 auto-rows-[minmax(300px,auto)]">
      
      <a href="/features#market-brief" class="md:col-span-2 relative group rounded-3xl bg-[#0A0A0A] border border-white/5 overflow-hidden flex flex-col min-h-[360px] md:min-h-[450px] transition-all duration-500 hover:border-gold-500/30 hover:shadow-[0_0_40px_-10px_rgba(221,170,51,0.15)]">
        <div class="relative z-20 p-6 md:p-8">
           <div class="flex items-center gap-3 mb-2">
             <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-gold-500/10 text-gold-400 border border-gold-500/20 uppercase tracking-wider">Flagship</span>
             <h3 class="text-xl md:text-2xl font-bold text-white">Daily Market Intelligence</h3>
           </div>
           <p class="text-slate-400 text-sm max-w-sm md:max-w-md group-hover:text-slate-300 transition-colors">
             Institutional daily bias & volatility matrix delivered before London Open.
           </p>
        </div>
        
        <div class="absolute inset-0 z-10 pointer-events-none flex flex-col">
            
            <div class="md:hidden w-full h-full flex items-center justify-center">
                <img src="https://raw.githubusercontent.com/Ozz310/tradersgazetteterminal/refs/heads/main/images/productshots/product_shot_v2_daily_market_intelligence.png" 
                     class="w-[85%] h-auto object-contain animate-float drop-shadow-2xl" 
                     alt="Daily Market Intelligence" />
            </div>

            <div class="hidden md:flex w-full h-full items-end justify-center pb-0 relative">
                <div class="absolute bottom-0 w-[60%] h-[40%] bg-gold-500/20 blur-[60px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700 ease-out"></div>
                <img src="https://raw.githubusercontent.com/Ozz310/tradersgazetteterminal/refs/heads/main/images/productshots/product_shot_v2_daily_market_intelligence.png" 
                     class="relative z-10 w-[80%] h-auto max-h-[85%] object-contain object-bottom 
                            transition-transform duration-700 ease-out 
                            group-hover:scale-105 group-hover:-translate-y-4 drop-shadow-2xl" 
                     alt="Daily Market Intelligence" />
            </div>
        </div>
      </a>

      <a href="/features#session-clock" class="md:row-span-3 relative group rounded-3xl bg-[#0A0A0A] border border-white/5 overflow-hidden flex flex-col min-h-[450px] md:min-h-auto transition-all duration-500 hover:border-gold-500/30 hover:shadow-[0_0_40px_-10px_rgba(221,170,51,0.15)]">
        <div class="relative z-20 p-6 md:p-8">
           <div class="flex justify-between items-start mb-2">
             <h3 class="text-xl md:text-2xl font-bold text-white">Session Clock</h3>
             <span class="text-[10px] font-mono text-gold-500 tracking-widest bg-black/50 px-2 py-1 rounded border border-gold-500/20 backdrop-blur-sm animate-pulse">LIVE</span>
           </div>
           <p class="text-slate-400 text-sm leading-relaxed">Visualize liquidity overlap zones.</p>
        </div>
        
        <div class="absolute inset-0 z-10 pointer-events-none flex flex-col">
            <div class="md:hidden w-full h-full flex items-center justify-center">
                <img src="https://raw.githubusercontent.com/Ozz310/tradersgazetteterminal/refs/heads/main/images/productshots/product_shot_v2_session_clock.png" 
                     class="w-[70%] h-auto object-contain animate-float drop-shadow-2xl" alt="Session Clock" />
            </div>
            <div class="hidden md:flex w-full h-full items-end justify-center pb-8 relative">
                 <div class="absolute bottom-10 w-[80%] h-[30%] bg-gold-500/10 blur-[50px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                <img src="https://raw.githubusercontent.com/Ozz310/tradersgazetteterminal/refs/heads/main/images/productshots/product_shot_v2_session_clock.png" 
                     class="relative z-10 w-full h-auto max-h-[85%] object-contain object-bottom 
                            transition-transform duration-700 ease-out 
                            group-hover:scale-105 group-hover:-translate-y-4 drop-shadow-2xl" 
                     alt="Session Clock" />
            </div>
        </div>
        <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-[#0A0A0A] to-transparent z-10 pointer-events-none hidden md:block"></div>
      </a>

      {[
        { t: "24/7 News Room", d: "Live feed aggregator.", link: "#news", img: "https://raw.githubusercontent.com/Ozz310/tradersgazetteterminal/refs/heads/main/images/productshots/product_shot_v2_news_room.png" },
        { t: "Analysis Hub", d: "Economic Calendar & Charts.", link: "#analysis", img: "https://raw.githubusercontent.com/Ozz310/tradersgazetteterminal/refs/heads/main/images/productshots/product_shot_v2_chart.png" },
        { t: "Trade Journal", d: "Track performance & equity.", link: "#journal", img: "https://raw.githubusercontent.com/Ozz310/tradersgazetteterminal/refs/heads/main/images/productshots/product_shot_v2_journal.png" },
        { t: "Knowledge Hub", d: "Premium E-books.", link: "#library", img: "https://raw.githubusercontent.com/Ozz310/tradersgazetteterminal/refs/heads/main/images/productshots/product_shot_v2_ebook_hub.png" }
      ].map((item) => (
        <a href={`/features${item.link}`} class="relative group rounded-3xl bg-[#0A0A0A] border border-white/5 overflow-hidden flex flex-col min-h-[300px] md:min-h-[280px] transition-all duration-500 hover:border-gold-500/30 hover:shadow-[0_0_30px_-10px_rgba(221,170,51,0.1)]">
          <div class="relative z-20 p-6">
            <h3 class="text-lg md:text-xl font-bold text-slate-200 mb-1 group-hover:text-white transition-colors">{item.t}</h3>
            <p class="text-slate-500 text-xs md:text-sm leading-relaxed group-hover:text-slate-400">{item.d}</p>
          </div>
          
          <div class="absolute inset-0 z-10 pointer-events-none flex flex-col">
              <div class="md:hidden w-full h-full flex items-center justify-center">
                  <img src={item.img} class="w-[80%] h-auto object-contain animate-float drop-shadow-xl" alt={item.t} />
              </div>
              <div class="hidden md:flex w-full h-full items-end justify-center pb-0 relative">
                  <div class="absolute bottom-0 w-[70%] h-[40%] bg-gold-500/15 blur-[40px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                  <img src={item.img} class="relative z-10 w-[85%] h-auto max-h-[65%] object-contain object-bottom 
                                            transition-transform duration-500 ease-out 
                                            group-hover:scale-105 group-hover:-translate-y-2 drop-shadow-xl" 
                       alt={item.t} />
              </div>
          </div>
          <div class="absolute inset-x-0 bottom-0 h-12 bg-gradient-to-t from-[#0A0A0A] to-transparent z-10 pointer-events-none hidden md:block"></div>
        </a>
      ))}

      <a href="/features#risk-hub" class="md:col-span-3 relative group rounded-3xl bg-[#0A0A0A] border border-white/5 overflow-hidden flex flex-col md:flex-row items-center min-h-[400px] md:min-h-[280px] transition-all duration-500 hover:border-gold-500/30 hover:shadow-[0_0_40px_-10px_rgba(221,170,51,0.15)]">
         <div class="absolute inset-0 bg-gradient-to-r from-[#0A0A0A] via-[#0A0A0A]/40 to-transparent z-10 pointer-events-none"></div>
         
         <div class="relative z-20 p-8 pb-40 md:pb-10 md:p-10 w-full md:w-1/2 text-center md:text-left">
            <div class="flex items-center justify-center md:justify-start gap-3 mb-4">
               <div class="p-2 rounded-lg bg-gold-500/10 border border-gold-500/20 text-gold-500">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
               </div>
               <h3 class="text-xl md:text-2xl font-bold text-white">Risk Management Console</h3>
            </div>
            <p class="text-slate-400 text-sm md:text-base mb-6 max-w-sm mx-auto md:mx-0">The professional's edge. Integrated calculator suite.</p>
            <span class="inline-flex items-center text-sm font-bold text-gold-400 group-hover:text-gold-300 transition-colors">Access Calculator <span class="ml-2 group-hover:translate-x-1 transition-transform">&rarr;</span></span>
         </div>

         <div class="absolute inset-0 z-0 pointer-events-none flex flex-col">
            <div class="md:hidden w-full h-full flex items-center justify-center pt-20">
                <img src="https://raw.githubusercontent.com/Ozz310/tradersgazetteterminal/refs/heads/main/images/productshots/product_shot_v2_calculator.png" 
                     class="w-[85%] h-auto object-contain animate-float drop-shadow-2xl opacity-50" alt="Calculator" />
            </div>
            <div class="hidden md:flex w-full h-full items-center justify-end pr-12 relative">
                <div class="absolute right-12 w-[40%] h-[50%] bg-gold-500/10 blur-[60px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                <img src="https://raw.githubusercontent.com/Ozz310/tradersgazetteterminal/refs/heads/main/images/productshots/product_shot_v2_calculator.png" 
                     class="relative z-10 w-[50%] h-auto object-contain 
                            transition-transform duration-700 ease-out 
                            group-hover:scale-105 group-hover:-translate-y-2 drop-shadow-2xl" 
                     alt="Calculator" />
            </div>
         </div>
      </a>

    </div>
  </div>
</section>

<style>
  /* Standard Floating Animation */
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
  }
  .animate-float {
    animation: float 5s ease-in-out infinite;
  }
</style>
